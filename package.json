{
  "name": "pi-extension-continuous-learning-v2",
  "description": "Continuous Learning v2 plugin for pi-coding-agent",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/opsCoffee/pi-continuous-learning-v2.git"
  },
  "homepage": "https://github.com/opsCoffee/pi-continuous-learning-v2",
  "bugs": {
    "url": "https://github.com/opsCoffee/pi-continuous-learning-v2/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "continuous-learning",
    "instincts"
  ],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "echo 'nothing to check'",
    "validate:scope": "npx tsx --tsconfig ./tsconfig.scripts.json ./scripts/scope-validation.mts",
    "validate:overlap": "npx tsx --tsconfig ./tsconfig.scripts.json ./scripts/overlap-validation.mts",
    "validate:observer": "npx tsx --tsconfig ./tsconfig.scripts.json ./scripts/observer-validation.mts --mode regression",
    "validate:observer:soak": "npx tsx --tsconfig ./tsconfig.scripts.json ./scripts/observer-validation.mts --mode soak --rounds 3"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  }
}
